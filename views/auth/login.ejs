<%- include('../partials/header') %>

<section class="hero-card auth-hero auth-hero--split">
  <div class="auth-intro">
    <span class="eyebrow">Вход в системата</span>
    <h1>Вход в платформата за училищни събития</h1>
    <p>
      Влез, за да управляваш ученически екскурзии, училищни събития, записвания,
      родителски съгласия, плащания и административен контрол в една система.
    </p>

    <div class="hero-chip-row">
      <span class="info-chip">Student bookings</span>
      <span class="info-chip">Teacher planning</span>
      <span class="info-chip">Parent approvals</span>
      <span class="info-chip">Admin control</span>
    </div>
  </div>

  <aside class="auth-visual">
    <img
      src="/public/hero-school-trip.svg"
      alt="Илюстрация на ученическа екскурзия и планиране на събития"
      class="auth-illustration"
    />

    <article class="auth-float-card">
      <span class="eyebrow">School journey</span>
      <h3>Организация от създаване до потвърждение</h3>
      <p>Учителят публикува, ученикът се записва, родителят одобрява, администраторът следи.</p>

      <div class="hero-chip-row">
        <span class="mini-pill">Audit log</span>
        <span class="mini-pill">Seat plan</span>
        <span class="mini-pill">Payments</span>
      </div>
    </article>
  </aside>
</section>

<section class="auth-layout auth-layout--travel">
    <form action="/login" method="post" class="panel form-card auth-card">
      <span class="eyebrow">Welcome back</span>
      <h2>Вход</h2>

      <% if (errorMessage) { %>
        <div class="inline-error"><%= errorMessage %></div>
      <% } %>

      <label>
        Имейл
        <input type="email" name="email" value="<%= formData.email %>" required />
      </label>

      <label>
        Парола
        <input type="password" name="password" required />
      </label>

      <button type="submit" class="primary-button full-width">Влез</button>

      <p class="muted-text">
        Нямаш профил? <a href="/register">Създай акаунт</a>
      </p>
    </form>

    <aside class="panel demo-card demo-card--travel">
      <span class="eyebrow">Demo access</span>
      <h3>Влез с примерни роли</h3>
      <p>Тези акаунти са удобни за demo на всички acceptance criteria и роли.</p>
      <ul class="credentials-list">
        <li><strong>Admin:</strong> <span class="credential-pill">admin@trippilot.local / Admin123!</span></li>
        <li><strong>Teacher:</strong> <span class="credential-pill">teacher@trippilot.local / Teacher123!</span></li>
        <li><strong>Student:</strong> <span class="credential-pill">student@trippilot.local / Student123!</span></li>
        <li><strong>Parent:</strong> <span class="credential-pill">parent@trippilot.local / Parent123!</span></li>
      </ul>
    </aside>
</section>

<%- include('../partials/footer') %>
