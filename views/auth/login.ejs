<%- include('../partials/header') %>

<section class="auth-layout auth-layout--travel auth-layout--simple">
    <form action="/login" method="post" class="panel form-card auth-card auth-card--primary">
      <span class="eyebrow">Welcome back</span>
      <h1 class="auth-form-title">Вход</h1>
      <p class="auth-form-copy">Влез в профила си и продължи с организацията на събитията.</p>

      <% if (errorMessage) { %>
        <div class="inline-error"><%= errorMessage %></div>
      <% } %>

      <label>
        Имейл
        <input type="email" name="email" value="<%= formData.email %>" required />
      </label>

      <label>
        Парола
        <input type="password" name="password" required />
      </label>

      <button type="submit" class="primary-button full-width">Влез</button>

      <p class="muted-text">
        Нямаш профил? <a href="/register">Създай акаунт</a>
      </p>
    </form>

    <aside class="panel demo-card demo-card--travel">
      <span class="eyebrow">Demo access</span>
      <h3>Влез с примерни роли</h3>
      <p>Тези акаунти са удобни за demo на всички acceptance criteria и роли.</p>
      <ul class="credentials-list">
        <li><strong>Admin:</strong> <span class="credential-pill">admin@trippilot.local / Admin123!</span></li>
        <li><strong>Teacher:</strong> <span class="credential-pill">teacher@trippilot.local / Teacher123!</span></li>
        <li><strong>Student:</strong> <span class="credential-pill">student@trippilot.local / Student123!</span></li>
        <li><strong>Parent:</strong> <span class="credential-pill">parent@trippilot.local / Parent123!</span></li>
      </ul>
    </aside>
</section>

<%- include('../partials/footer') %>
