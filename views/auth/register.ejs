<%- include('../partials/header') %>

<section class="auth-layout auth-layout--travel auth-layout--simple auth-layout--register">
  <form action="/register" method="post" class="panel form-card auth-card auth-card--primary auth-card--wide">
    <span class="eyebrow">Create profile</span>
    <h1 class="auth-form-title">Регистрация</h1>
    <p class="auth-form-copy">Създай профил и избери роля в платформата за училищни събития.</p>

    <% if (errorMessage) { %>
      <div class="inline-error"><%= errorMessage %></div>
    <% } %>

    <div class="form-grid two-columns">
      <label>
        Име и фамилия
        <input type="text" name="name" value="<%= formData.name %>" required />
      </label>

      <label>
        Имейл
        <input type="email" name="email" value="<%= formData.email %>" required />
      </label>

      <label>
        Парола
        <input type="password" name="password" required />
      </label>

      <label>
        Роля
        <select name="role" required>
          <% roleOptions.forEach((option) => { %>
            <option value="<%= option.value %>" <%= formData.role === option.value ? 'selected' : '' %>>
              <%= option.label %>
            </option>
          <% }) %>
        </select>
      </label>
    </div>

    <label>
      Имейл на ученик за свързване с родител
      <input
        type="email"
        name="linkedStudentEmail"
        value="<%= formData.linkedStudentEmail %>"
        placeholder="Използва се само ако ролята е Родител"
      />
    </label>

    <button type="submit" class="primary-button">Създай акаунт</button>

    <p class="muted-text">
      Вече имаш профил? <a href="/login">Влез тук</a>
    </p>
  </form>

  <aside class="panel demo-card demo-card--travel">
    <span class="eyebrow">Registration notes</span>
    <h3>Подготвено за user stories и acceptance criteria</h3>
    <div class="feature-grid feature-grid--stacked">
      <div class="feature-tile">
        <strong>Validation</strong>
        <p>Проверяват се валиден имейл и минимална дължина на паролата.</p>
      </div>
      <div class="feature-tile">
        <strong>Roles</strong>
        <p>Регистрацията позволява student, teacher, parent и admin flow в системата.</p>
      </div>
      <div class="feature-tile">
        <strong>Database</strong>
        <p>След успешна регистрация акаунтът се записва и може да влезе в платформата.</p>
      </div>
    </div>
  </aside>
</section>

<%- include('../partials/footer') %>
