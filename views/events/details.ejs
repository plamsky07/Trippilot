<%- include('../partials/header') %>

<section class="hero-card hero-card--details">
  <div class="hero-main detail-main">
    <span class="eyebrow"><%= event.category %></span>
    <h1><%= event.title %></h1>
    <p class="hero-copy"><%= event.description %></p>

    <div class="hero-chip-row">
      <span class="info-chip"><%= event.target_group %></span>
      <span class="info-chip"><%= event.event_date %></span>
      <span class="info-chip"><%= event.departure_time %></span>
      <span class="info-chip"><%= event.location %></span>
    </div>

    <div class="hero-metrics hero-metrics--detail">
      <article class="metric-card">
        <span>Цена</span>
        <strong><%= formatPrice(event.price) %></strong>
      </article>
      <article class="metric-card">
        <span>Свободни места</span>
        <strong><%= availableSeats %></strong>
      </article>
      <article class="metric-card">
        <span>Организатор</span>
        <strong><%= event.organizer_name %></strong>
      </article>
    </div>
  </div>

  <div class="panel detail-sidecard detail-sidecard--travel">
    <div class="detail-sidecard-top">
      <span class="spotlight-overline">Event Overview</span>
      <span class="status-pill <%= event.status %>"><%= event.status === 'open' ? 'Отворено' : 'Отменено' %></span>
    </div>

    <h2>Информация</h2>
    <dl class="meta-grid">
      <div>
        <dt>Клас</dt>
        <dd><%= event.target_group %></dd>
      </div>
      <div>
        <dt>Дата</dt>
        <dd><%= event.event_date %></dd>
      </div>
      <div>
        <dt>Час</dt>
        <dd><%= event.departure_time %></dd>
      </div>
      <div>
        <dt>Локация</dt>
        <dd><%= event.location %></dd>
      </div>
      <div>
        <dt>Организатор</dt>
        <dd><%= event.organizer_name %> · <%= event.organizer_email %></dd>
      </div>
      <div>
        <dt>Свободни места</dt>
        <dd><%= availableSeats %> / <%= event.seats_total %></dd>
      </div>
    </dl>

    <div class="card-actions vertical">
      <% if (currentUser.role === 'student' && event.status === 'open') { %>
        <% if (studentRegistration && studentRegistration.status === 'registered') { %>
          <div class="status-stack">
            <span class="status-badge <%= studentRegistration.parent_approval_status %>">
              Съгласие: <%= studentRegistration.parent_approval_status %>
            </span>
            <span class="status-badge <%= studentRegistration.payment_status %>">
              Плащане: <%= studentRegistration.payment_status %>
            </span>
          </div>
          <form action="/events/<%= event.id %>/unregister" method="post">
            <button type="submit" class="ghost-button danger">Отказвам участие</button>
          </form>
        <% } else { %>
          <form action="/events/<%= event.id %>/register" method="post">
            <button type="submit" class="primary-button" <%= availableSeats <= 0 ? 'disabled' : '' %>>
              Запиши се
            </button>
          </form>
        <% } %>
      <% } %>

      <% if (currentUser.role === 'teacher' || currentUser.role === 'admin') { %>
        <a href="/events/<%= event.id %>/edit" class="ghost-button button-link">Редакция</a>
        <a href="/events/<%= event.id %>/participants" class="ghost-button button-link">Участници</a>
        <% if (event.status === 'open') { %>
          <form action="/events/<%= event.id %>/cancel" method="post">
            <button type="submit" class="ghost-button danger">Отмени събитието</button>
          </form>
        <% } %>
      <% } %>
    </div>
  </div>
</section>

<section class="detail-content-grid">
  <article class="panel editorial-card editorial-card--large">
    <span class="eyebrow">What is tracked</span>
    <h2>Всички важни детайли за участието са събрани на едно място</h2>
    <div class="feature-grid">
      <div class="feature-tile">
        <strong>Регистрация</strong>
        <p>Следим кой ученик е записан и кой се е отказал.</p>
      </div>
      <div class="feature-tile">
        <strong>Родителско съгласие</strong>
        <p>Потвърждението остава видимо в detail view и в организационния поток.</p>
      </div>
      <div class="feature-tile">
        <strong>Плащане и места</strong>
        <p>Организаторът управлява payment status и seat plan от една и съща система.</p>
      </div>
    </div>
  </article>

  <article class="panel editorial-card">
    <span class="eyebrow">Quick Notes</span>
    <h3>Ясна страница за организацията на събитието</h3>
    <p>
      Тук остават същите данни, роли и действия от проекта, но подредени в
      по-ясна визуална структура за учители, ученици, родители и администратори.
    </p>
  </article>
</section>

<% if (currentUser.role === 'parent' && parentLinkedRegistrations.length > 0) { %>
  <section class="panel">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Родителско действие</span>
        <h2>Потвърждение за ученик</h2>
      </div>
    </div>

    <% parentLinkedRegistrations.forEach((registration) => { %>
      <div class="approval-card">
        <div>
          <strong><%= registration.student_name %></strong>
          <p class="muted-text">Статус: <%= registration.approval_status %></p>
        </div>

        <% if (registration.approval_status === 'pending') { %>
          <div class="inline-actions">
            <form action="/registrations/<%= registration.registration_id %>/approval" method="post">
              <input type="hidden" name="approvalStatus" value="approved" />
              <button type="submit" class="small-button success">Одобри</button>
            </form>
            <form action="/registrations/<%= registration.registration_id %>/approval" method="post">
              <input type="hidden" name="approvalStatus" value="rejected" />
              <button type="submit" class="small-button danger">Откажи</button>
            </form>
          </div>
        <% } %>
      </div>
    <% }) %>
  </section>
<% } %>

<%- include('../partials/footer') %>
